{
  "name": "mindmap-vscode",
  "displayName": "Mindmap (MindmapEditor)",
  "icon": "media/icon.png",
  "description": "WYSIWYG mindmap editor inside VS Code (webview). Supports multiple formats.",
  "version": "0.0.150",
  "publisher": "av-ai-dev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Productivity"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCustomEditor:mindmap.customTextEditor",
    "onCommand:mindmapVscode.openMindmapEditor",
    "onCommand:mindmapVscode.openWithMindmap",
    "onCommand:mindmapVscode.toggleDock",
    "onCommand:mindmapVscode.toggleWorkbenchFullScreen",
    "onCommand:mindmapVscode.newMindmapFile"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mindmap.customTextEditor",
        "displayName": "Mindmap Editor",
        "selector": [
          {
            "filenamePattern": "*.mmd"
          },
          {
            "filenamePattern": "*.jm"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "mindmapVscode.openMindmapEditor",
        "title": "Mindmap: Open Mindmap Editor"
      },
      {
        "command": "mindmapVscode.openWithMindmap",
        "title": "Mindmap: Open with Mindmap Editor"
      },
      {
        "command": "mindmapVscode.toggleDock",
        "title": "Mindmap: Toggle Dock Maximized",
        "category": "Mindmap"
      },
      {
        "command": "mindmapVscode.toggleWorkbenchFullScreen",
        "title": "Mindmap: Toggle Workbench Full Screen",
        "category": "Mindmap"
      },
      {
        "command": "mindmapVscode.closeMindmapEditor",
        "title": "Mindmap: Close Editor (Save Prompt if Dirty)",
        "category": "Mindmap"
      },
      {
        "command": "mindmapVscode.focusMindmapEditor",
        "title": "Mindmap: Focus Mindmap Editor",
        "category": "Mindmap"
      },
      {
        "command": "mindmapVscode.quitWithUnsavedCheck",
        "title": "Mindmap: Quit (Check Unsaved Mindmaps)",
        "category": "Mindmap"
      },
      {
        "command": "mindmapVscode.showMcpBridgeInfo",
        "title": "Mindmap: Show MCP Bridge Info",
        "category": "Mindmap"
      },
      {
        "command": "mindmapVscode.configureCursorMcpWorkspace",
        "title": "Mindmap: Configure Cursor MCP (Workspace .cursor/mcp.json)",
        "category": "Mindmap"
      },
      {
        "command": "mindmapVscode.configureCursorMcpUser",
        "title": "Mindmap: Configure Cursor MCP (User ~/.cursor/mcp.json)",
        "category": "Mindmap"
      },
      {
        "command": "mindmapVscode.diagnoseMcpSetup",
        "title": "Mindmap: Diagnose MCP Setup",
        "category": "Mindmap"
      },
      {
        "command": "mindmapVscode.newMindmapFile",
        "title": "Mindmap: New Mindmap File…",
        "category": "Mindmap"
      }
    ],
    "configuration": {
      "title": "Mindmap",
      "properties": {
        "mindmap.mcpBridge.enable": {
          "type": "boolean",
          "default": true,
          "description": "Listen on 127.0.0.1 for the Pencil-style Mindmap MCP HTTP bridge."
        },
        "mindmap.mcpBridge.port": {
          "type": "number",
          "default": 58741,
          "description": "TCP port for the MCP bridge (localhost only)."
        },
        "mindmap.mcpBridge.token": {
          "type": "string",
          "default": "",
          "description": "Shared secret for MCP bridge. If empty, a token is generated once and stored in global state (use Show MCP Bridge Info to copy)."
        },
        "mindmap.statusBar.newMindmapButton": {
          "type": "boolean",
          "default": true,
          "description": "Show a status bar button to create a new .mmd / .jm mindmap file (save dialog)."
        },
        "mindmap.mcpBridge.cursorConfig": {
          "type": "string",
          "enum": ["off", "prompt", "workspace"],
          "default": "prompt",
          "enumDescriptions": [
            "不自动写入 Cursor MCP 配置",
            "每个工作区首次检测到未配置 user-mindmap 时弹窗询问是否写入 .cursor/mcp.json",
            "打开工作区时若尚无 user-mindmap 则自动合并写入 .cursor/mcp.json（使用扩展内置 MCP 路径）"
          ],
          "description": "如何将 Mindmap MCP 注册到 Cursor（args 使用扩展安装目录，无需手写盘符路径）。"
        },
        "mindmap.webview.dumpHtml": {
          "type": "boolean",
          "default": false,
          "description": "将当前 webview HTML 额外写入扩展 out/last_webview_debug.html（仅排障时开启）。"
        }
      }
    },
    "keybindings": [
      {
        "command": "mindmapVscode.toggleWorkbenchFullScreen",
        "key": "ctrl+space",
        "mac": "ctrl+space",
        "when": "mindmapActiveTabIsMindmap"
      },
      {
        "command": "mindmapVscode.toggleDock",
        "key": "ctrl+shift+space",
        "mac": "ctrl+shift+space",
        "when": "mindmapActiveTabIsMindmap"
      },
      {
        "command": "mindmapVscode.closeMindmapEditor",
        "key": "ctrl+f4",
        "when": "(activeWebviewPanelId == 'mindmapEditor' || mindmapActiveTabIsMindmap) && mindmapEditorHasUnsavedChanges"
      },
      {
        "command": "mindmapVscode.closeMindmapEditor",
        "key": "ctrl+w",
        "mac": "cmd+w",
        "when": "(activeWebviewPanelId == 'mindmapEditor' || mindmapActiveTabIsMindmap) && mindmapEditorHasUnsavedChanges"
      },
      {
        "command": "mindmapVscode.quitWithUnsavedCheck",
        "key": "ctrl+q",
        "mac": "cmd+q",
        "when": "mindmapEditorHasUnsavedChanges && (activeWebviewPanelId == 'mindmapEditor' || mindmapActiveTabIsMindmap)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "mindmapVscode.openWithMindmap",
          "when": "true",
          "group": "2_open@15"
        }
      ],
      "openEditors/context": [
        {
          "command": "mindmapVscode.openWithMindmap",
          "when": "true",
          "group": "2_open@15"
        }
      ],
      "editor/context": [
        {
          "command": "mindmapVscode.openWithMindmap",
          "when": "editorTextFocus",
          "group": "navigation@50"
        }
      ],
      "editor/title/context": [
        {
          "command": "mindmapVscode.openWithMindmap",
          "when": "true",
          "group": "1_open@15"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run mcp:pack",
    "compile": "tsc -p ./",
    "gen:web-dev": "node scripts/gen_web_dev_html.js 127.0.0.1 8765",
    "watch": "tsc -p ./ --watch",
    "mcp:pack": "npm install --prefix mcp-server && npm run build --prefix mcp-server"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "adm-zip": "0.5.16",
    "jsmind": "0.9.1"
  }
}

